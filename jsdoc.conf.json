{
  "source": {
    "include": ["src", "lib/Browser", "README.md", "tsup.config.ts", "test/Test.ts"],
    "includePattern": ".+\\.ts$",
    "excludePattern": "(node_modules/|docs/|dist/)"
  },
  "plugins": ["plugins/markdown", "node_modules/jsdoc-babel"],
  "babel": {
    "extensions": ["ts", "tsx"],
    "presets": ["@babel/preset-env", "@babel/preset-typescript"]
  },
  "opts": {
    "encoding": "utf8",
    "readme": "./README.md",
    "destination": "docs/",
    "recurse": true,
    "verbose": true,
    "template": "./node_modules/clean-jsdoc-theme",
    "theme_opts": {
      "shouldRemoveScrollbarStyle": false,
      "includeFilesListInHomepage": true,
      "search": true,
      "sections": ["Namespaces", "Interfaces", "Modules", "Global"],
      "homepageTitle": "btch-downloader",
      "title": "btch-downloader Documentation",
      "default_theme": "light",
      "exclude_inherited": false,
      "add_scripts": "function foo(){console.log('foo')} function bar() {console.log('bar')} bar(); foo();",
      "create_style": "html { font-size: 14px !important; }",
      "displayModuleHeader": true,
      "footer": "<div style='margin-bottom: 0.5rem;'>btch-downloader</div> Fork: <a href='https://github.com/hostinger-bot/btch-downloader'>https://github.com/hostinger-bot/btch-downloader</a>",
      "favicon": "/favicon.png",
      "meta": [
        {
          "name": "author",
          "content": "Tio"
        },
        {
          "name": "description",
          "content": "A lightweight TypeScript/JavaScript library for downloading media from social media platforms."
        }
      ],
      "menu": [
        {
          "title": "Home",
          "id": "home-link",
          "link": "/",
          "class": "nav-link"
        },
        {
          "title": "Github",
          "id": "github-link",
          "link": "https://github.com/hostinger-bot/btch-downloader",
          "class": "nav-link"
        },
        {
          "title": "npm",
          "id": "npm-link",
          "link": "https://www.npmjs.com/package/btch-downloader",
          "class": "nav-link"
        },
        {
          "title": "Backend",
          "id": "be-link",
          "link": "https://backend1.tioo.eu.org",
          "class": "nav-link"
        },
        {
          "title": "Website",
          "id": "web-link",
          "link": "https://tio.is-a.dev",
          "class": "nav-link"
        },
        {
          "title": "Demo",
          "id": "demo-link",
          "link": "/example.html",
          "class": "nav-link"
        },
        {
          "title": "Documentation API",
          "id": "api-link",
          "link": "https://backend1.tioo.eu.org/docs/api-reference",
          "class": "nav-link"
        },
        {
          "title": "Donate",
          "id": "donate-link",
          "link": "https://sociabuzz.com/tioclkp02/give",
          "class": "nav-link"
        }
      ],
      "prefixModuleToSidebarItems_experimental": true
    }
  },
  "markdown": {
    "hardwrap": true,
    "idInHeadings": true
  }
}
